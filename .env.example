# --- Database (Neon / Postgres) ---
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- PayFast ---
# Sandbox: PAYFAST_MODE=sandbox, use test credentials below
# Live: PAYFAST_MODE=live, replace with your real merchant ID/key from payfast.co.za
PAYFAST_MERCHANT_ID="10000100"
PAYFAST_MERCHANT_KEY="46f0cd694581a"
PAYFAST_PASSPHRASE=""
PAYFAST_MODE="sandbox"

# --- Email (Gmail SMTP) ---
# GMAIL_USER: your Gmail address
# GMAIL_APP_PASSWORD: 16-char App Password from Google Account > Security > App Passwords
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# --- App ---
# Local dev: http://localhost:3000
# Production (set in Vercel dashboard): https://leadbron.vercel.app
APP_URL="http://localhost:3000"

# --- Admin dashboard ---
ADMIN_TOKEN="change-me-to-a-long-random-string"

# The guided chat widget needs no API keys — it runs entirely on this app.
